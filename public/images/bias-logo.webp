  <style>
main {
	 display: flex;
	 justify-content: center;
	 align-items: center;
	 min-height: 40vh;
	 max-width: 100%;
}
 .container {
	 max-width: 100%;
}
 .hero {
	 margin: 0;
	 font-size: 6em;
	 font-weight: bold;
	 line-height: 0.85;
	 letter-spacing: -0.05em;
	 text-transform: uppercase;
}
 .hero span {
	 display: block;
	 word-wrap: break-word;
}
 .hero span.bigger {
	 font-size: 1.5em;
}
 .links {
	 color: #666;
	 margin: 4em 0 0;
}
 .links a {
	 color: #666;
	 text-decoration: none;
}
 .links a:first-child {
	 font-weight: bold;
	 margin-left: 0.6em;
}
 .links a:not(:first-child) {
	 margin-left: 0.6em;
}
 @media (max-width: 720px) {
	 .hero {
		 font-size: 4em;
	}
}
  </style>

  <title>BIAS, Bhimtal</title>
</head>

<body>
